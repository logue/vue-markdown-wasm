{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "vue-markdown-wasm",
  "description": "markdown-wasm for vue 2 & 3",
  "version": "1.1.0",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "vue",
    "vue-markdown",
    "markdown",
    "markdown-wasm",
    "vue2",
    "vue3",
    "vue-component",
    "nuxt",
    "ssr",
    "server-side-rendering"
  ],
  "author": {
    "name": "Logue",
    "email": "logue@hotmail.co.jp",
    "url": "https://logue.dev/"
  },
  "homepage": "https://github.com/logue/vue-markdown-wasm",
  "repository": {
    "type": "git",
    "url": "git@github.com:logue/vue-markdown-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/logue/vue-markdown-wasm/issues"
  },
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "unpkg": "dist/index.iife.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.es.js"
    },
    "./nuxt": {
      "import": "./dist/nuxt.js",
      "types": "./dist/nuxt.d.ts",
      "default": "./dist/nuxt.js"
    },
    "./umd": {
      "default": "./dist/index.umd.js"
    },
    "./iife": {
      "default": "./dist/index.iife.js"
    }
  },
  "files": [
    "/dist",
    "./src/components/VueMarkdown.ts",
    "./src/nuxt.ts",
    "./src/nuxt.d.ts"
  ],
  "sideEffects": false,
  "browser": {
    "./sfc": "./src/components/VueMarkdown.ts"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10.3.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "clean": "rimraf node_modules/.vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:analyze": "vite build --mode=analyze",
    "build:clean": "rimraf dist docs",
    "build:docs": "vite build --mode=docs",
    "lint": "eslint --fix --cache && prettier . --write",
    "preview": "vite preview --mode=docs",
    "build-only": "vite build",
    "postbuild": "node -e \"const fs=require('fs'); fs.copyFileSync('src/nuxt.ts', 'dist/nuxt.js'); fs.copyFileSync('src/nuxt.d.ts', 'dist/nuxt.d.ts');\"",
    "type-check": "vue-tsc --build --force",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky install",
    "version": "auto-changelog -p && git add CHANGELOG.md"
  },
  "dependencies": {
    "vue-demi": "latest"
  },
  "peerDependencies": {
    "@logue/markdown-wasm": ">=1.6.1",
    "@vue/composition-api": "^1.7.2",
    "vue": "^2.0.0 || >=3.0.0"
  },
  "peerDependenciesMeta": {
    "@vue/composition-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "6.5.0",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/emscripten": "^1.41.5",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.3.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-linter-browserify": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-vue": "^10.9.0",
    "github-markdown-css": "^5.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vite-plugin-banner": "^0.8.1",
    "vite-plugin-checker": "0.13.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5",
    "vue": "3.5.33",
    "vue-codemirror6": "1.5.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,json,yaml,yml,vue,htm,html,md}": "eslint --fix --cache",
    "*": "prettier -w -u"
  },
  "resolutions": {
    "lodash": ">=4.18.1",
    "rollup": ">=4.60.2"
  }
}
